# URL e anon key: pubbliche, usate solo per il login (Supabase Auth) lato browser.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon...

# Service role key: SEGRETA. Bypassa RLS, usata SOLO nei Server Component/Action.
# Su Vercel: Project Settings -> Environment Variables, NON esporre come NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...
